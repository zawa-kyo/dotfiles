#!/usr/bin/env bash
#MISE description="Emit shell snippets for eval-style sourcing"

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

if [ -t 1 ]; then
  echo 'NOTE: This is auto-loaded from .zshrc, so you usually do not need to run it manually. If you do run it via mise, use `eval "$(mise run -q source)"` to apply exports to the current shell.' 1>&2
  exit 0
fi

bash "$repo_root/scripts/source.sh"

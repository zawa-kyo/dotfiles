[user]
  name = Kyohei Ozawa
  email = zawazawakyo@gmail.com

[init]
  defaultBranch = main

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

[color]
  ui = auto

[ghq]
  root = ~/Library/CloudStorage/Dropbox/Git/ghq

[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  light = false

[merge]
  conflictstyle = zdiff3

[diff]
  colorMoved = default

[push]
  default = simple

[include]
  path = ~/.gitconfig.local

def allow(pattern, justification):
    prefix_rule(
        pattern = pattern,
        decision = "allow",
        justification = justification,
    )


def forbid(pattern, justification, match, not_match = []):
    prefix_rule(
        pattern = pattern,
        decision = "forbidden",
        justification = justification,
        match = match,
        not_match = not_match,
    )


for command in [
    "basename",
    "dirname",
    "pwd",
    "readlink",
    "realpath",
    "which",
]:
    allow([command], "Allows low-risk path and working directory inspection.")

for command in [
    "bat",
    "cat",
    "cut",
    "file",
    "head",
    "jq",
    "sed",
    "sort",
    "stat",
    "tail",
    "tr",
    "uniq",
    "wc",
]:
    allow([command], "Allows low-risk file and command output inspection.")

for command in [
    "df",
    "du",
    "ls",
    "eza",
    "fd",
    "find",
    "grep",
    "rg",
    "tree",
]:
    allow([command], "Allows low-risk filesystem discovery and search.")

for command in [
    "date",
    "printenv",
    "ps",
    "uname",
    "whoami",
]:
    allow([command], "Allows low-risk environment and system inspection.")

for command in [
    "cd",
    "z",
]:
    allow([command], "Allows low-risk working directory changes during shell inspection.")

for command in [
    "cp",
    "mkdir",
    "mv",
    "touch",
]:
    allow([command], "Allows existing low-risk workspace file maintenance commands.")

allow(
    ["git", [
        "blame",
        "branch",
        "diff",
        "grep",
        "log",
        "ls-files",
        "remote",
        "rev-parse",
        "show",
        "status",
    ]],
    "Allows read-only Git inspection.",
)

forbid(
    ["git", "add"],
    "Do not allow Codex to stage changes.",
    match = ["git add README.md", "git add ."],
    not_match = ["git status --short"],
)

forbid(
    ["git", "commit"],
    "Do not allow Codex to create commits.",
    match = ["git commit -m update"],
    not_match = ["git log --oneline"],
)

forbid(
    ["git", "push"],
    "Do not allow Codex to push changes.",
    match = ["git push", "git push origin main"],
    not_match = ["git remote -v"],
)

allow(
    ["gh", "auth", "status"],
    "Allows read-only GitHub authentication inspection via gh CLI.",
)

allow(
    ["gh", "issue", ["list", "status", "view"]],
    "Allows read-only GitHub issue inspection via gh CLI.",
)

allow(
    ["gh", "pr", ["checks", "diff", "list", "status", "view"]],
    "Allows read-only GitHub pull request inspection via gh CLI.",
)

allow(
    ["gh", "release", ["list", "view"]],
    "Allows read-only GitHub release inspection via gh CLI.",
)

allow(
    ["gh", "repo", ["list", "view"]],
    "Allows read-only GitHub repository inspection via gh CLI.",
)

allow(
    ["gh", "run", ["list", "view"]],
    "Allows read-only GitHub Actions inspection via gh CLI.",
)

allow(
    ["gh", "search", ["code", "commits", "issues", "prs", "repos"]],
    "Allows read-only GitHub search via gh CLI.",
)
